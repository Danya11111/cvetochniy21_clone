# Локальная / staging копия переменных окружения (скопируйте в `.env` при необходимости).
# Полный production-шаблон для сервера (`/etc/cvetochny21.env`) — в `deploy/env.example`.

APP_PUBLIC_URL=http://127.0.0.1:3000
BASE_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_SUPERGROUP_ID=

# Канонические thread_id см. docs/telegram-forum-topics-ru.md (+ legacy TELEGRAM_*_NOTIFY_THREAD_ID в deploy/env.example).
TELEGRAM_TOPIC_ORDERS_ID=
TELEGRAM_TOPIC_SUPPORT_ID=
TELEGRAM_TOPIC_BROADCASTS_ID=
# Опционально: отдельная тема для сервисных ошибок (пусто = как поддержка через backend/config.js)
TELEGRAM_TOPIC_ERRORS_ID=
# Опционально: если пусто/0 — уведомления «брошенных корзин» в тему Telegram не включаются (админка+БД остаются).
TELEGRAM_TOPIC_ABANDONED_CARTS_ID=
# ABANDONED_CART_TELEGRAM_NOTIFICATIONS_ENABLED=

# Abandoned carts (опционально; см. backend/config.js, deploy/env.example)
# ABANDONED_CARTS_ENABLED=0
# ABANDONED_CART_AFTER_MINUTES=30
# ABANDONED_CART_NOTIFY_AFTER_MINUTES=30
# ABANDONED_CART_REPEAT_NOTIFY_HOURS=24
# ABANDONED_CART_MAX_NOTIFICATIONS=2
# ABANDONED_CART_EXPIRE_DAYS=30
# ABANDONED_CART_SCAN_INTERVAL_MINUTES=5
# Если env не задан, Telegram-пуш включается только при ненулевом TELEGRAM_TOPIC_ABANDONED_CARTS_ID.
# Личные сообщения клиенту о брошенной корзине (кнопка в админке / сканер):
# ABANDONED_CART_CLIENT_NOTIFICATIONS_ENABLED=true
# Если ключ не задан — по умолчанию как TELEGRAM_OUTBOUND_BOT_HTTP_ENABLED.

# Владелец Mini App-админки: только этот Telegram ID может добавлять/удалять записи в admin_users (см. backend/admin-routes.js).
ADMIN_OWNER_TG_ID=67460775
ADMIN_INITIAL_TG_IDS=67460775
ADMIN_TELEGRAM_IDS=

TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
TBANK_API_URL=https://securepay.tinkoff.ru/v2

MOYSKLAD_TOKEN=
MOYSKLAD_ORGANIZATION_HREF=
MOYSKLAD_STORE_HREF=
MOYSKLAD_AGENT_HREF=
MOYSKLAD_PROJECT_HREF=

F21_ADMIN_OPEN_SECRET=
