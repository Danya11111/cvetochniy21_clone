# Шаблон тестового деплоя (Нидерланды, arhipovdan.ru). Скопировать: /etc/cvetochny21.env, chmod 640, chown root:www-data.
# Не коммитить с реальными токенами. TELEGRAM_BOT_TOKEN и SECRET вставляются только на сервере.
#
# NL / EU: TELEGRAM_PROXY_URL=direct (или пусто — в коде по умолчанию прямой Bot API, без SOCKS).
# Старый RU с локальным SOCKS: TELEGRAM_PROXY_URL=socks5h://127.0.0.1:1080
# Если TELEGRAM_PROXY_URL не задан вовсе, используется прямое подключение к api.telegram.org.

NODE_ENV=production
PORT=3000
LISTEN_HOST=127.0.0.1

BASE_URL=https://arhipovdan.ru
MINI_APP_URL=https://arhipovdan.ru

TELEGRAM_BOT_TOKEN=<TEST_BOT_TOKEN>
TELEGRAM_WEBHOOK_SECRET=<NEW_LONG_RANDOM_SECRET>
TELEGRAM_OUTBOUND_BOT_HTTP_ENABLED=1
TELEGRAM_PROXY_URL=direct

F21_ADMIN_OPEN_SECRET=<NEW_LONG_RANDOM_32PLUS>
F21_SQLITE_PATH=/var/lib/cvetochny21/database.sqlite

TELEGRAM_FORUM_GROUP_ID=-1003847910699
TELEGRAM_BROADCAST_TOPIC_CHAT_ID=-1003847910699
TELEGRAM_BROADCAST_TOPIC_THREAD_ID=4
TELEGRAM_ORDERS_NOTIFY_CHAT_ID=-1003847910699
TELEGRAM_ORDERS_NOTIFY_THREAD_ID=2
TELEGRAM_SUPPORT_NOTIFY_CHAT_ID=-1003847910699
TELEGRAM_SUPPORT_NOTIFY_THREAD_ID=6

TELEGRAM_TOPICS_ENABLED=1
BROADCASTS_ENABLED=1
SUPPORT_RELAY_ENABLED=1
ORDERS_TOPIC_NOTIFICATIONS_ENABLED=1
CLIENT_TOPIC_REPLY_ENABLED=1

EVENT_PUBLISHER_ENABLED=1
EVENT_OUTBOX_ENABLED=1
OUTBOX_WORKER_ENABLED=1

BROADCAST_TOPIC_TEST_MODE=1
BROADCAST_DELIVERY_INTERVAL_MS=55
BROADCAST_GLOBAL_MESSAGES_PER_SEC=18

MOYSKLAD_TOKEN=<PLACEHOLDER_OR_TEST_TOKEN>
MOYSKLAD_ACCOUNT_ID=<PLACEHOLDER>
MOYSKLAD_DEFAULT_AGENT_ID=<PLACEHOLDER>
MOYSKLAD_DELIVERY_CITY400_ASSORTMENT=<PLACEHOLDER>
MOYSKLAD_DELIVERY_TO10KM_ASSORTMENT=<PLACEHOLDER>

TBANK_TERMINAL_KEY=<PLACEHOLDER_TEST_TERMINAL>
TBANK_PASSWORD=<PLACEHOLDER_TEST_PASSWORD>
