# Единый шаблон переменных для production (/etc/cvetochny21.env).
# Скопируйте на сервер, заполните значения, выставьте права chmod 600.
# Маркеры:
#   [required prod] — нужно задать осмысленное значение в production
#   [recommended] — сильно рекомендуется
#   [optional] — есть безопасный дефолт в backend/config.js

# --- core / runtime ---
NODE_ENV=production
# [optional] путь к SQLite (по умолчанию `backend/database.sqlite` относительно процесса)
# F21_SQLITE_PATH=/var/lib/cvetochny21/app.sqlite

# [optional] порт процесса Node (Express)
PORT=3000
# [optional] адрес bind (за reverse proxy: 127.0.0.1; иначе по умолчанию 0.0.0.0)
# LISTEN_HOST=127.0.0.1
# [recommended] канонический публичный origin без завершающего «/»: Success/Fail/T-Bank webhook, абсолютные ссылки.
# Если не задан, backend использует BASE_URL (см. backend/config.js: APP_PUBLIC_URL).
APP_PUBLIC_URL=https://your-domain.example
# [recommended] синоним/legacy для публичного URL — можно оставить пустым, если задан APP_PUBLIC_URL.
BASE_URL=
# [optional] Mini App URL для кнопок; пусто = BASE_URL
# MINI_APP_URL=
# [optional] явный build id для versioned assets; иначе git SHA / BUILD_ID — см. backend/frontend-build-id.js
# F21_FRONTEND_BUILD=

# --- admin access ---
# [recommended] Telegram ID владельца админки (полный доступ; нельзя удалить из списка). Алиас к legacy ADMIN_PRIMARY_TELEGRAM_ID при пустом значении там.
ADMIN_OWNER_TG_ID=67460775
# Первичный bootstrap таблицы admin_users при пустой БД (CSV). Дальнейший источник истины — БД и экран «Администраторы» у владельца.
ADMIN_INITIAL_TG_IDS=67460775
# [recommended] CSV доп. администраторов (env + совместимость; union с дефолтом backend/config.js)
ADMIN_TELEGRAM_IDS=
# [optional legacy]
ADMIN_PRIMARY_TELEGRAM_ID=
# Отдельный CSV: объединяется с ADMIN_TELEGRAM_IDS при проверке initData (admin-auth.js).
# Для старта рассылки из темы используется только этот список в broadcast-service: пусто = разрешён любой участник форума.
TELEGRAM_ADMIN_IDS=
# [required prod] HMAC для signed URL /admin-embed (32+ символов)
F21_ADMIN_OPEN_SECRET=GENERATE_RANDOM_SECRET
# [optional]
# ADMIN_INITDATA_MAX_AGE_SEC=86400
# ADMIN_UI_ENABLED=1
# ADMIN_MINIAPP_EMBED_ENABLED=1
# ADMIN_PRIMARY_USERNAME=
# ADMIN_PRIMARY_FIRST_NAME=
# ADMIN_PRIMARY_LAST_NAME=

# --- telegram bot (core) ---
# [required prod]
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
# [required prod] секрет для verify webhook
TELEGRAM_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
# [optional] @username без @ — внешние ссылки; кнопка «Позвать менеджера» в welcome = callback, не URL
TELEGRAM_BOT_USERNAME=your_bot_username
# [required prod] супергруппа-форум (один chat_id для служебных тем).
# Приоритет: TELEGRAM_SUPERGROUP_ID → TELEGRAM_FORUM_GROUP_ID → TELEGRAM_ADMIN_CHAT_ID
TELEGRAM_SUPERGROUP_ID=-100YOUR_FORUM_SUPERGROUP_CHAT_ID_HERE
TELEGRAM_FORUM_GROUP_ID=-100YOUR_FORUM_SUPERGROUP_CHAT_ID_HERE
# TELEGRAM_ADMIN_CHAT_ID=
# [required prod] исходящие HTTPS к api.telegram.org (уведомления, рассылка, топики)
TELEGRAM_OUTBOUND_BOT_HTTP_ENABLED=1

# --- telegram proxy ---
# По умолчанию (env не задан) — прямой HTTPS к api.telegram.org, без SOCKS.
# EU/NL: оставьте direct или пусто (или none/off/false/0).
# RU/SSH SOCKS на 127.0.0.1:1080: задайте явно, например:
# TELEGRAM_PROXY_URL=socks5h://127.0.0.1:1080
TELEGRAM_PROXY_URL=direct

# --- topics / threads (форум) ---
# chat_id у служебных тем по умолчанию = TELEGRAM_SUPERGROUP_ID (или переопределения TELEGRAM_*_NOTIFY_CHAT_ID ниже).
# thread_id: из ссылки t.me/c/<short>/<thread> (message_thread_id в Bot API).
#
# На сервере в супергруппе обычно используются **только 3 операционные темы**:
#   1) Заказы
#   2) Поддержка
#   3) Рассылки
# Отдельной темы для «брошенных корзин» нет и не нужна: снимки лежат в SQLite и доступны только в админке.
#
# Канонические thread_id ключи — `TELEGRAM_TOPIC_*` (см. docs/telegram-forum-topics-ru.md).
#
# Для поддержки ошибок можно задать отдельный `TELEGRAM_TOPIC_ERRORS_ID`; если ключ пустой — маршрутизация
# ошибок может совпасть с темой поддержки (см. `TELEGRAM_ERRORS_NOTIFY_THREAD_ID` в backend/config.js).
#
TELEGRAM_TOPIC_ORDERS_ID=12102
TELEGRAM_TOPIC_SUPPORT_ID=12104
TELEGRAM_TOPIC_BROADCASTS_ID=12106
TELEGRAM_TOPIC_ERRORS_ID=
#
# Отдельная тема форума для брошенных корзин **опциональна** (можно держать пустым/`0`/не задавать).
# Если `TELEGRAM_TOPIC_ABANDONED_CARTS_ID` не задан/ноль — телеграм-уведомления по abandoned cart теме не включены автоматически.
# Принудительный выключатель (даже если thread_id указан вручную):
# ABANDONED_CART_TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_TOPIC_ABANDONED_CARTS_ID=

TELEGRAM_BROADCAST_TOPIC_CHAT_ID=-100YOUR_FORUM_SUPERGROUP_CHAT_ID_HERE
TELEGRAM_BROADCAST_TOPIC_THREAD_ID=12106
# Legacy алиасы (если нужно сохранять старые имена):
# TELEGRAM_BROADCASTS_THREAD_ID=${TELEGRAM_TOPIC_BROADCASTS_ID}
TELEGRAM_ORDERS_NOTIFY_CHAT_ID=-100YOUR_FORUM_SUPERGROUP_CHAT_ID_HERE
TELEGRAM_ORDERS_NOTIFY_THREAD_ID=12102
# TELEGRAM_ORDERS_THREAD_ID=${TELEGRAM_TOPIC_ORDERS_ID}
TELEGRAM_SUPPORT_NOTIFY_CHAT_ID=-100YOUR_FORUM_SUPERGROUP_CHAT_ID_HERE
TELEGRAM_SUPPORT_NOTIFY_THREAD_ID=12104
# TELEGRAM_SUPPORT_THREAD_ID=${TELEGRAM_TOPIC_SUPPORT_ID}

# --- feature flags ---
TELEGRAM_TOPICS_ENABLED=1
BROADCASTS_ENABLED=1
SUPPORT_RELAY_ENABLED=1
ORDERS_TOPIC_NOTIFICATIONS_ENABLED=1
CLIENT_TOPIC_REPLY_ENABLED=1
EVENT_PUBLISHER_ENABLED=1
EVENT_OUTBOX_ENABLED=1
OUTBOX_WORKER_ENABLED=1
# OUTBOX_WORKER_INTERVAL_MS=5000
BROADCAST_DELETE_ENABLED=0

# --- abandoned carts (серверные снимки «до заказа») ---
# ABANDONED_CARTS_ENABLED=0
# ABANDONED_CART_AFTER_MINUTES=30
# ABANDONED_CART_NOTIFY_AFTER_MINUTES=30
# ABANDONED_CART_REPEAT_NOTIFY_HOURS=24
# ABANDONED_CART_MAX_NOTIFICATIONS=2
# ABANDONED_CART_EXPIRE_DAYS=30
# ABANDONED_CART_SCAN_INTERVAL_MINUTES=5
# По умолчанию Telegram-уведомления включаются только при ненулевом TELEGRAM_TOPIC_ABANDONED_CARTS_ID:
# ABANDONED_CART_TELEGRAM_NOTIFICATIONS_ENABLED=
# Личные сообщения клиенту (без темы форума). Если не задано — по умолчанию как TELEGRAM_OUTBOUND_BOT_HTTP_ENABLED.
# ABANDONED_CART_CLIENT_NOTIFICATIONS_ENABLED=true

# --- broadcast tuning ---
# [optional] тестовая рассылка только на перечисленные id
BROADCAST_TOPIC_TEST_MODE=1
BROADCAST_TOPIC_TEST_TELEGRAM_IDS=id1,id2
# BROADCAST_TOPIC_TEST_LABEL=Тестовая рассылка
BROADCAST_DELIVERY_INTERVAL_MS=55
BROADCAST_GLOBAL_MESSAGES_PER_SEC=18
BROADCAST_WORKER_CONCURRENCY=4
BROADCAST_PER_CHAT_MIN_INTERVAL_MS=1000
BROADCAST_RETRY_WAVE_POLL_MS=400
BROADCAST_DELIVERY_WAVE_BATCH_SIZE=500
BROADCAST_MAX_COPY_ATTEMPTS=8
# Подряд transport-like ошибок copyMessage без успеха в волне → PAUSED_TRANSPORT (circuit breaker)
BROADCAST_TRANSPORT_BREAKER_COPY_STREAK=12
# Активный probe getMe (тот же proxy/axios), backoff при ошибках
TELEGRAM_TRANSPORT_PROBE_ENABLED=1
TELEGRAM_TRANSPORT_PROBE_INTERVAL_MS=60000
TELEGRAM_TRANSPORT_PROBE_BACKOFF_MAX_MS=300000
TELEGRAM_TRANSPORT_PROBE_INITIAL_DELAY_MS=8000
TELEGRAM_TRANSPORT_PROBE_PREFLIGHT_TRUST_MS=120000
# Авто-resume PAUSED_TRANSPORT после восстановления транспорта
BROADCAST_PAUSED_AUTO_RESUME_MIN_INTERVAL_MS=120000
BROADCAST_PAUSED_AUTO_RESUME_PER_CAMPAIGN_MS=180000
BROADCAST_PAUSED_TRANSPORT_SWEEP_MS=45000

# Профили throughput (ориентиры; подбирайте под прокси и 429 — см. docs/broadcast-ops-ru.md):
# small (~до 2k): консервативнее, например BROADCAST_GLOBAL_MESSAGES_PER_SEC=12 BROADCAST_WORKER_CONCURRENCY=3
# medium (2k–20k): значения выше по умолчанию ок
# large (20k+): только при стабильном транспорте; не занижайте BROADCAST_PER_CHAT_MIN_INTERVAL_MS без причины

# --- integrations (Moysklad / T-Bank) — задайте свои ---
# [optional] неоплаченный заказ можно обновлять при повторном checkout не дольше этого окна (мс); по умолчанию 86400000 (24 ч)
# CHECKOUT_EXISTING_ORDER_REUSE_MAX_MS=86400000

# MOYSKLAD_TOKEN=
# Ссылки meta.href из интерфейса МойСклад API (никаких секретов; без хардкода в коде).
# MOYSKLAD_ORGANIZATION_HREF=
# MOYSKLAD_STORE_HREF=
# MOYSKLAD_AGENT_HREF=
# MOYSKLAD_PROJECT_HREF=
# MOYSKLAD_ACCOUNT_ID=
# MOYSKLAD_ORGANIZATION_NAME=
# MOYSKLAD_DEFAULT_AGENT_ID=
# MOYSKLAD_DELIVERY_CITY400_ASSORTMENT=
# MOYSKLAD_DELIVERY_TO10KM_ASSORTMENT=
# MOYSKLAD_ROOT_FOLDER_NAME=
# MOYSKLAD_ROOT_FOLDER_EXTERNAL_CODE=
# Автосоздание канала продаж «Telegram Bot» при отсутствии в МС (POST /entity/saleschannel; по умолчанию выкл. — checkout без salesChannel)
# MOYSKLAD_SALESCHANNEL_AUTO_CREATE=0
# TBANK_TERMINAL_KEY=
# TBANK_PASSWORD=
# Боевое API Т-Банка (эквайринг v2); для теста см. документацию Т‑Банка.
# TBANK_API_URL=https://securepay.tinkoff.ru/v2

# --- misc telegram / onboarding (optional, см. config.js) ---
# TELEGRAM_CHANNEL_URL=
# TELEGRAM_CONSENT_PUBLIC_PATH=/public/cvetochny21-consent.pdf
# TELEGRAM_CONSENT_PDF_PATH=
# TELEGRAM_CONSENT_DOCUMENT_URL=
# TELEGRAM_START_WELCOME_IMAGE_URL=
# TELEGRAM_START_WELCOME_IMAGE_PATH=
# TELEGRAM_ONBOARDING_MANAGER_DELAY_MS=5000
# TELEGRAM_ONBOARDING_CHANNEL_DELAY_MS=15000
# Антиспам кнопки «Позвать менеджера» после успешного уведомления в тему поддержки (мс; по умолчанию 420000)
# MANAGER_HELP_COOLDOWN_MS=420000
# TELEGRAM_DEBUG_BOT_API=0
